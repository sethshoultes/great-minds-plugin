# Great Minds Daemon — Environment Variables
# Copy this file to .env and fill in your values

# Claude authentication — mount your ~/.claude directory
# The daemon needs Claude Code authenticated to dispatch agents
CLAUDE_CONFIG_DIR=~/.claude

# Git config for commits
GIT_CONFIG=~/.gitconfig

# Optional: override the repo URL (defaults to great-minds)
# REPO_URL=https://github.com/YOUR_USERNAME/great-minds.git

# Optional: OpenAI key for TTS voiceover and image generation
# OPENAI_API_KEY=sk-...

# Optional: Cloudflare API token for deployments
# CLOUDFLARE_API_TOKEN=...

# Optional: Resend API key for email
# RESEND_API_KEY=re_...
