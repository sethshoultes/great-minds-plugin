# Great Minds Daemon — Environment Variables
# Copy this file to .env and fill in your values

# Claude authentication — mount your ~/.claude directory
# The daemon needs Claude Code authenticated to dispatch agents
CLAUDE_CONFIG_DIR=~/.claude

# Git config for commits
GIT_CONFIG=~/.gitconfig

# Optional: override the repo URL (defaults to great-minds)
# REPO_URL=https://github.com/YOUR_USERNAME/great-minds.git

# Optional: OpenAI key for TTS voiceover and image generation
# OPENAI_API_KEY=sk-...

# Optional: Cloudflare API token for deployments
# CLOUDFLARE_API_TOKEN=...

# Optional: Resend API key for email
# RESEND_API_KEY=re_...

# ─── Telegram Notifications ─────────────────────────────────
# Get a bot token from @BotFather on Telegram.
# Get your chat ID by messaging your bot and calling:
#   https://api.telegram.org/bot<TOKEN>/getUpdates
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
# TELEGRAM_CHAT_ID=123456789

# ─── Agent Timeout (hung detection) ─────────────────────────
# Maximum time (ms) for a single agent call before it's killed and retried.
# Default: 600000 (10 minutes)
# AGENT_TIMEOUT_MS=600000

# ─── Pipeline Timeout (watchdog) ────────────────────────────
# Maximum time (ms) for an entire pipeline run before the watchdog
# force-skips it and moves to the next PRD.
# Default: 3600000 (60 minutes)
# PIPELINE_TIMEOUT_MS=3600000
